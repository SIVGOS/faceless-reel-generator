# Copy to .env and fill in. Never commit the real .env.

# Google AI Studio API key
GEMINI_API_KEY=your-google-ai-studio-key

# Gemini model used to write the reel script
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# Gemini embedding model (wired through config for future semantic features)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Secret used to sign session JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Session lifetime (minutes)
JWT_EXPIRE_MINUTES=10080

# edge-tts narration voice
TTS_VOICE=en-US-ChristopherNeural

# faster-whisper model size (tiny|base|small). base = good CPU tradeoff.
WHISPER_MODEL=base

# Background video library — kept OUTSIDE the repo so large .mp4 files are never
# pushed to git. Set this to a local folder of 9:16 .mp4 loops. In Docker this
# host path is mounted read-only into the container.
BG_VIDEO_FOLDER_PATH=./backgrounds

# ============================================================================
# v2 — config is now read by the app (defaults shown). Behavior lands per the
# BUILD_PLAN.md checkpoints: voice (C), captions (D), music (F), admin (G).
# All are optional overrides; the defaults below are what the app uses unset.
# ============================================================================
# Voice (checkpoint C). gemini = native Gemini TTS; edge = free fallback.
# TTS_PROVIDER=gemini                          # gemini | edge
# TTS_GEMINI_MODEL=gemini-3.1-flash-tts-preview
# TTS_GEMINI_VOICE=Kore                        # 30 voices: Kore, Puck, Zephyr, ...
# TTS_STYLE_PROMPT=Read as a warm, confident, upbeat narrator. Natural pacing.
# If the Gemini TTS call fails (quota/region/transient), fall back to edge-tts so
# the render still completes. Set false to surface the error instead.
# TTS_FALLBACK_TO_EDGE=true

# Captions (checkpoint D).
# CAPTION_ENGINE=moviepy                       # moviepy (chosen) | ass (light) | remotion (future)

# Render job cap, seconds (checkpoint B).
# RENDER_TIMEOUT_SECONDS=900

# Background-music pool (checkpoint F) — mirrors BG_VIDEO_FOLDER_PATH: external,
# mounted read-only. Falls back to ./music.
# MUSIC_FOLDER_PATH=./music

# First admin, auto-promoted on startup (checkpoint G). Once public signup is
# closed, this is your way in — set it before deploying.
# ADMIN_EMAIL=you@example.com
